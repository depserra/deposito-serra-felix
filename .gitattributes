# Normaliza todas as quebras de linha para LF no repositório
* text=auto eol=lf

# Arquivos de texto explicitamente com LF
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf

# Arquivos binários — não converter
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
